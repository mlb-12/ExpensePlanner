<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.trial.DashboardController"
      spacing="10" alignment="TOP_CENTER" prefWidth="900" prefHeight="700">

    <Label fx:id="totalLabel" text="Total Expenses: 0" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <HBox spacing="20" alignment="CENTER">
        <PieChart fx:id="categoryChart" title="Expenses by Category" prefWidth="400" prefHeight="300"/>
        <BarChart fx:id="monthlyChart" title="Monthly Expenses" prefWidth="400" prefHeight="300">
            <xAxis>
                <CategoryAxis label="Month" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Amount" />
            </yAxis>
        </BarChart>
    </HBox>

    <TableView fx:id="tableView" prefHeight="350" prefWidth="880">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
            <TableColumn fx:id="titleCol" text="Title" prefWidth="150" />
            <TableColumn fx:id="categoryCol" text="Category" prefWidth="150" />
            <TableColumn fx:id="amountCol" text="Amount" prefWidth="100" />
            <TableColumn fx:id="typeCol" text="Type" prefWidth="100" />
            <TableColumn fx:id="dateCol" text="Date" prefWidth="130" />
        </columns>
    </TableView>

</VBox>
